{
  "name": "storefront-agent-audit",
  "version": "0.1.0",
  "description": "Audit what AI shopping agents can actually see on a Shopify storefront. Agent-first: designed to be run by your AI assistant.",
  "keywords": [
    "shopify",
    "agentic-commerce",
    "ai-agents",
    "llms-txt",
    "audit",
    "geo",
    "aeo",
    "mcp",
    "ucp"
  ],
  "license": "MIT",
  "author": "Alec Hewstone",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahwstn/storefront-agent-audit.git"
  },
  "homepage": "https://github.com/ahwstn/storefront-agent-audit#readme",
  "bugs": "https://github.com/ahwstn/storefront-agent-audit/issues",
  "type": "module",
  "bin": {
    "storefront-agent-audit": "./dist/cli.js",
    "storefront-agent-audit-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist",
    "SKILL.md",
    "agents.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/cli.ts src/mcp.ts --format esm --clean --dts",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
